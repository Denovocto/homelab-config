# Homelab Configuration
# Copy this file to ~/.config/homelab.env or /etc/homelab.env and customize as needed

# Repository location (defaults to ~/homelab-config if not set)
# HOMELAB_REPO_DIR="$HOME/homelab-config"

# Alternative locations you might use:
# HOMELAB_REPO_DIR="$HOME/Documents/projects/minecraft-server-tools"
# HOMELAB_REPO_DIR="/opt/homelab"
# HOMELAB_REPO_DIR="/srv/homelab"
