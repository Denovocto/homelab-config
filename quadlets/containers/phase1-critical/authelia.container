[Unit]
Description=Authelia SSO
After=network-online.target homelab-network.service

[Container]
Image=docker.io/authelia/authelia:latest
ContainerName=authelia
AutoUpdate=registry

# Run as non-root user (recommended by Authelia)
User=1000:1000

Network=homelab.network

# Port not published - Caddy accesses Authelia via internal homelab network
# PublishPort=9091:9091

# Config directory (contains configuration.yml and users_database.yml)
Volume=%h/homelab-config/configs/authelia:/config:Z

# Environment configuration
EnvironmentFile=%h/homelab-config/configs/authelia/authelia.env

# Secrets (injected as environment variables)
Secret=authelia-jwt-secret,type=env,target=AUTHELIA_JWT_SECRET
Secret=authelia-session-secret,type=env,target=AUTHELIA_SESSION_SECRET
Secret=authelia-storage-key,type=env,target=AUTHELIA_STORAGE_ENCRYPTION_KEY
Secret=authelia-oidc-hmac-secret,type=env,target=AUTHELIA_OIDC_HMAC_SECRET
Secret=authelia-oidc-private-key,type=env,target=AUTHELIA_OIDC_ISSUER_PRIVATE_KEY
Secret=homarr-oidc-client-secret,type=env,target=HOMARR_OIDC_CLIENT_SECRET
Secret=grafana-oidc-client-secret,type=env,target=GRAFANA_OIDC_CLIENT_SECRET

[Service]
Restart=always

[Install]
WantedBy=default.target
