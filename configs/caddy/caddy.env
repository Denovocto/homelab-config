# Caddy Reverse Proxy Configuration
# See: https://caddyserver.com/docs/

# =============================================================================
# Optional: Email for ACME (Let's Encrypt)
# =============================================================================

# Email address for SSL certificate notifications
# Uncomment and set if you want to receive expiry warnings
# ACME_EMAIL=your@email.com

# =============================================================================
# Optional: Logging
# =============================================================================

# Log level (DEBUG, INFO, WARN, ERROR)
# CADDY_LOG_LEVEL=INFO

# =============================================================================
# Optional: Admin API
# =============================================================================

# Admin API endpoint (disabled by default on port 2019)
# CADDY_ADMIN=localhost:2019

# =============================================================================
# Optional: Cloudflare API Token
# =============================================================================

# Cloudflare API token is configured via Podman secret
# No need to set CLOUDFLARE_API_TOKEN here
