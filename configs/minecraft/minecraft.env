# Minecraft Pixelmon Server Configuration
# Environment variables for itzg/minecraft-server container
# See: https://github.com/itzg/docker-minecraft-server

# =============================================================================
# Server Basics
# =============================================================================

# Accept Minecraft EULA
EULA=TRUE

# Server type
TYPE=FORGE

# Minecraft version
VERSION=1.16.5

# Forge version
FORGE_VERSION=36.2.39

# Game mode
MODE=survival

# Server name and MOTD
SERVER_NAME=Pixelmon en una papa
MOTD="Pixelmon on a Potato"

# =============================================================================
# Memory Configuration
# =============================================================================

# Maximum memory allocation
MEMORY=4G

# Initial memory allocation
INIT_MEMORY=2G

# =============================================================================
# Mods
# =============================================================================

# Mod download URLs (comma-separated)
# 1. Pixelmon Reforged - Main modpack
# 2. FTB Ranks - Server ranks/permissions
# 3. FTB Library - Dependency for FTB Ranks
# 4. Architectury - API library dependency
# 5. Prometheus Exporter - For metrics collection
MODS=https://dl.reforged.gg/4dvlYEb,https://mediafilez.forgecdn.net/files/3802/698/ftb-ranks-forge-1605.1.6-build.33.jar,https://mediafilez.forgecdn.net/files/3553/840/ftb-library-forge-1605.3.4-build.90.jar,https://mediafilez.forgecdn.net/files/4521/290/architectury-1.32.68.jar,https://mediafilez.forgecdn.net/files/4110/51/Prometheus-Exporter-1.16.5-forge-1.0.0.jar

# =============================================================================
# Server Operators
# =============================================================================

# Server operators (comma-separated usernames)
# Replace with your actual Minecraft username(s)
OPS=YourMinecraftUsername

# =============================================================================
# Metrics & Monitoring
# =============================================================================

# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port (must match PublishPort in Quadlet)
METRICS_PORT=19565

# =============================================================================
# Logging
# =============================================================================

# Enable rolling logs to prevent disk space issues
ENABLE_ROLLING_LOGS=true

# =============================================================================
# Optional: Discord Integration
# =============================================================================

# Discord webhook is configured via Podman secret: minecraft-discord-webhook
# No need to set DISCORD_WEBHOOK here

# =============================================================================
# Optional: World Configuration
# =============================================================================

# Uncomment and configure as needed:

# Level name (world folder name)
# LEVEL=world

# Level seed
# SEED=

# Max players
# MAX_PLAYERS=20

# View distance
# VIEW_DISTANCE=10

# Difficulty (peaceful, easy, normal, hard)
# DIFFICULTY=normal

# PVP enabled
# PVP=true

# Whitelist enabled
# ENABLE_WHITELIST=false

# Online mode (true = requires Mojang authentication)
# ONLINE_MODE=true

# =============================================================================
# Optional: Performance Tuning
# =============================================================================

# JVM options (advanced users only)
# JVM_OPTS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled

# Server properties override
# Override any server.properties value using:
# OVERRIDE_SERVER_PROPERTIES=true
# Then use property names like:
# MAX_TICK_TIME=60000
