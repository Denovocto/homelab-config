# Grafana Configuration
# See: https://grafana.com/docs/grafana/latest/setup-grafana/configure-grafana/

# =============================================================================
# Server Configuration
# =============================================================================

# Root URL (update with your actual domain)
GF_SERVER_ROOT_URL=https://grafana.yourdomain.com

# =============================================================================
# Security
# =============================================================================

# Admin password file location (configured via Podman secret)
GF_SECURITY_ADMIN_PASSWORD__FILE=/run/secrets/grafana_admin_password

# Allow embedding (if using in iframes)
# GF_SECURITY_ALLOW_EMBEDDING=false

# =============================================================================
# Plugins
# =============================================================================

# Comma-separated list of plugins to install automatically
# Examples: grafana-clock-panel,grafana-simple-json-datasource
GF_INSTALL_PLUGINS=

# =============================================================================
# Optional: Authentication
# =============================================================================

# Disable login form (use only if using external auth like Authelia)
# GF_AUTH_DISABLE_LOGIN_FORM=false

# Anonymous access
# GF_AUTH_ANONYMOUS_ENABLED=false
# GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# =============================================================================
# Optional: SMTP (for email alerts)
# =============================================================================

# SMTP configuration (uncomment and configure if needed)
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.gmail.com:587
# GF_SMTP_USER=your-email@gmail.com
# GF_SMTP_PASSWORD=your-app-password
# GF_SMTP_FROM_ADDRESS=your-email@gmail.com
# GF_SMTP_FROM_NAME=Grafana

# =============================================================================
# Optional: Performance
# =============================================================================

# Logging level (debug, info, warn, error, critical)
# GF_LOG_LEVEL=info
