# Grafana Configuration
# See: https://grafana.com/docs/grafana/latest/setup-grafana/configure-grafana/

# =============================================================================
# Server Configuration
# =============================================================================

# Root URL (update with your actual domain)
GF_SERVER_ROOT_URL=https://grafana.yourdomain.com

# =============================================================================
# Security
# =============================================================================

# Admin password file location (configured via Podman secret)
GF_SECURITY_ADMIN_PASSWORD__FILE=/run/secrets/grafana_admin_password

# Allow embedding (if using in iframes)
# GF_SECURITY_ALLOW_EMBEDDING=false

# =============================================================================
# Plugins
# =============================================================================

# Comma-separated list of plugins to install automatically
# Examples: grafana-clock-panel,grafana-simple-json-datasource
GF_INSTALL_PLUGINS=

# =============================================================================
# Generic OAuth (OIDC with Authelia)
# =============================================================================

# Enable Generic OAuth
GF_AUTH_GENERIC_OAUTH_ENABLED=true
GF_AUTH_GENERIC_OAUTH_NAME=Authelia
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana
# GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET is injected via podman secret
GF_AUTH_GENERIC_OAUTH_SCOPES=openid profile email groups
GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://auth.yourdomain.com/api/oidc/authorization
GF_AUTH_GENERIC_OAUTH_TOKEN_URL=https://auth.yourdomain.com/api/oidc/token
GF_AUTH_GENERIC_OAUTH_API_URL=https://auth.yourdomain.com/api/oidc/userinfo
GF_AUTH_GENERIC_OAUTH_LOGIN_ATTRIBUTE_PATH=preferred_username
GF_AUTH_GENERIC_OAUTH_GROUPS_ATTRIBUTE_PATH=groups
GF_AUTH_GENERIC_OAUTH_NAME_ATTRIBUTE_PATH=name
GF_AUTH_GENERIC_OAUTH_EMAIL_ATTRIBUTE_PATH=email
GF_AUTH_GENERIC_OAUTH_USE_PKCE=false

# Auto login (skip Grafana login page)
GF_AUTH_OAUTH_AUTO_LOGIN=true

# Allow users to sign up via OAuth
GF_AUTH_GENERIC_OAUTH_ALLOW_SIGN_UP=true

# Role mapping based on Authelia groups
# Users in "admins" group get Admin role, otherwise Editor
GF_AUTH_GENERIC_OAUTH_ROLE_ATTRIBUTE_PATH=contains(groups[*], 'admins') && 'Admin' || contains(groups[*], 'users') && 'Editor' || 'Viewer'

# Disable direct login form (force OAuth only)
GF_AUTH_DISABLE_LOGIN_FORM=false

# Anonymous access (disabled for security)
GF_AUTH_ANONYMOUS_ENABLED=false

# =============================================================================
# Optional: SMTP (for email alerts)
# =============================================================================

# SMTP configuration (uncomment and configure if needed)
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.gmail.com:587
# GF_SMTP_USER=your-email@gmail.com
# GF_SMTP_PASSWORD=your-app-password
# GF_SMTP_FROM_ADDRESS=your-email@gmail.com
# GF_SMTP_FROM_NAME=Grafana

# =============================================================================
# Optional: Performance
# =============================================================================

# Logging level (debug, info, warn, error, critical)
# GF_LOG_LEVEL=info
