# Homarr Environment Configuration
# Documentation: https://homarr.dev/docs/

# Network binding (bind to all interfaces)
HOST=0.0.0.0
PORT=7575

# Encryption Key (REQUIRED - set via podman secret)
# Generate: openssl rand -hex 32
# Create secret: echo "your-key" | podman secret create homarr-encryption-key -
# SECRET_ENCRYPTION_KEY is injected via podman secret in the quadlet file

# Logging
LOG_LEVEL=info

# Timezone
TZ=UTC

# Base URL (optional - set if using reverse proxy with custom domain)
# BASE_URL=https://homarr.yourdomain.com

# Authentication - OIDC with Authelia (enables auto-registration)
# AUTH_OIDC_CLIENT_SECRET is injected via podman secret in quadlet
AUTH_PROVIDERS=oidc,credentials
AUTH_OIDC_ISSUER=https://auth.yourdomain.com
AUTH_OIDC_CLIENT_ID=homarr
AUTH_OIDC_CLIENT_NAME=Authelia
AUTH_OIDC_FORCE_USERINFO=true

# Disable analytics (optional)
# DISABLE_ANALYTICS=true
