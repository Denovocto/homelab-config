# Authelia SSO Configuration
# See: https://www.authelia.com/configuration/prologue/introduction/

# =============================================================================
# System Configuration
# =============================================================================

# Timezone for logs and timestamps
TZ=America/New_York

# =============================================================================
# Logging
# =============================================================================

# Log level (trace, debug, info, warn, error)
# AUTHELIA_LOG_LEVEL=info

# Log format (text, json)
# AUTHELIA_LOG_FORMAT=text

# =============================================================================
# Optional: Telemetry
# =============================================================================

# Disable telemetry
# AUTHELIA_TELEMETRY_METRICS_ENABLED=false
