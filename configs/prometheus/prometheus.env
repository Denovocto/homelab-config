# Prometheus Configuration
# See: https://prometheus.io/docs/prometheus/latest/configuration/configuration/

# =============================================================================
# System Configuration
# =============================================================================

# Timezone for timestamps
TZ=America/New_York

# =============================================================================
# Optional: Storage Configuration
# =============================================================================

# Retention time (default: 15 days)
# Uncomment to override
# PROMETHEUS_RETENTION_TIME=30d

# Retention size (default: unlimited)
# Uncomment to limit storage usage
# PROMETHEUS_RETENTION_SIZE=10GB

# =============================================================================
# Optional: Performance Tuning
# =============================================================================

# Max samples per query (default: 50000000)
# PROMETHEUS_QUERY_MAX_SAMPLES=100000000

# Query timeout (default: 2m)
# PROMETHEUS_QUERY_TIMEOUT=5m
